<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:desktop_app.ViewModels.Generation"
             xmlns:models="clr-namespace:desktop_app.Models.EnemyGeneration"
             x:Class="desktop_app.Views.EnemyGenerationView"
             x:DataType="vm:EnemyGenerationViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="*,560">

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22"
                VerticalAlignment="Top"
                BoxShadow="0 10 30 0 #14000000">

            <StackPanel Spacing="18">

                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16">

                    <Grid ColumnDefinitions="*,Auto">

                        <StackPanel Spacing="4">
                            <TextBlock Text="Stage Profiles"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <TextBlock Text="Configure enemy generation stages and progression balancing."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Create Profile"
                                Classes="detailsBtn"
                                Click="CreateStageProfile_Click"/>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <TextBlock Text="No stage profiles yet"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"
                           IsVisible="{Binding !HasProfiles}"/>

                <ItemsControl ItemsSource="{Binding Profiles}"
                              IsVisible="{Binding HasProfiles}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate x:DataType="models:StageProfile">

                            <Border Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,10">

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="16">

                                    <StackPanel Grid.Column="0"
                                                Spacing="6">

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <WrapPanel ItemWidth="120">

                                            <Border Background="#1E3A8A"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding StageIndex, StringFormat=Stage {0}}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>

                                            <Border Background="#27272A"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding Weight, StringFormat=Weight: {0}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>

                                            <Border Background="#27272A"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding Falloff, StringFormat=Falloff: {0}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>

                                            <Border Background="#27272A"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding Threshold, StringFormat=Threshold: {0}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>

                                        </WrapPanel>

                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">

                                        <Button Content="Details"
                                                Classes="detailsBtn"
                                                Command="{Binding #Root.((vm:EnemyGenerationViewModel)DataContext).SelectProfileCommand}"
                                                CommandParameter="{Binding}"/>

                                        <Button Content="Delete"
                                                Classes="blockBtn"
                                                Click="DeleteStageProfile_Click"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16"
                        Margin="0,10,0,0">

                    <Grid ColumnDefinitions="*,Auto">

                        <StackPanel Spacing="4">
                            <TextBlock Text="Enemy Class Profiles"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <TextBlock Text="Define enemy archetypes and generation constraints."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Create Class Profile"
                                Classes="detailsBtn"
                                Click="CreateEnemyClassProfile_Click"/>
                    </Grid>
                </Border>

                <TextBlock Text="No enemy class profiles yet"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"
                           IsVisible="{Binding !HasClassProfiles}"/>

                <ItemsControl ItemsSource="{Binding ClassProfiles}"
                              IsVisible="{Binding HasClassProfiles}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate x:DataType="models:EnemyClassProfile">

                            <Border Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,10">

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="16">

                                    <StackPanel Grid.Column="0"
                                                Spacing="6">

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <Border Background="#1E3A8A"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Class}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>

                                        <TextBlock FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="Generation Profile: "/>
                                            <Run Text="{Binding GenerationProfileDisplay}"/>
                                            <Run Text=" · Weight: "/>
                                            <Run Text="{Binding Weight}"/>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6">

                                            <TextBlock Text="Allowed Columns:"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>

                                            <ItemsControl ItemsSource="{Binding AllowedColumns}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>

                                                        <Border Background="#27272A"
                                                                CornerRadius="999"
                                                                Padding="8,3"
                                                                Margin="0,0,4,4">

                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                                                        </Border>

                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>

                                            </ItemsControl>

                                        </StackPanel>

                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Delete"
                                            Classes="blockBtn"
                                            VerticalAlignment="Center"
                                            Click="DeleteEnemyClassProfile_Click"/>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20"
                Margin="20,0,0,0"
                Height="720"
                VerticalAlignment="Top"
                BoxShadow="0 10 30 0 #14000000"
                IsVisible="{Binding HasSelectedProfile}">

            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <TextBlock Grid.Row="0"
                           Text="Profile Details"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel Grid.Row="1"
                            Margin="0,18,0,18"
                            Spacing="6">

                    <TextBlock Text="{Binding SelectedProfile.Name}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="Configure scenarios, slots and enemy distributions."
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False">

                    <StackPanel Spacing="18">

                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto">

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Scenarios"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Scenario groups controlling encounter density."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Create Scenario"
                                        Classes="detailsBtn"
                                        Click="CreateStageScenario_Click"/>

                            </Grid>

                        </Border>

                        <TextBlock Text="No scenarios yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding !HasScenarios}"/>

                        <ItemsControl ItemsSource="{Binding Scenarios}"
                                      IsVisible="{Binding HasScenarios}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate x:DataType="models:StageScenario">

                                    <Border Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="0,0,0,8">

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">

                                            <StackPanel Grid.Column="0"
                                                        Spacing="6">

                                                <TextBlock FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="Enemy Count: "/>
                                                    <Run Text="{Binding EnemyCount}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="Weight: "/>
                                                    <Run Text="{Binding Weight}"/>
                                                </TextBlock>

                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">

                                                <Button Content="Details"
                                                        Classes="detailsBtn"
                                                        Command="{Binding #Root.((vm:EnemyGenerationViewModel)DataContext).SelectScenarioCommand}"
                                                        CommandParameter="{Binding}"/>

                                                <Button Content="Delete"
                                                        Classes="blockBtn"
                                                        Click="DeleteStageScenario_Click"/>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                IsVisible="{Binding HasSelectedScenario}">

                            <Grid ColumnDefinitions="*,Auto">

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Scenario Slots"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Enemy slot distribution for the selected scenario."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Create Slot"
                                        Classes="detailsBtn"
                                        Click="CreateScenarioSlot_Click"/>

                            </Grid>

                        </Border>

                        <TextBlock Text="No slots yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding HasSelectedScenarioWithoutSlots}"/>

                        <ItemsControl ItemsSource="{Binding Slots}"
                                      IsVisible="{Binding HasSlots}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate x:DataType="models:ScenarioSlot">

                                    <Border Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="0,0,0,8">

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">

                                            <StackPanel Grid.Column="0"
                                                        Spacing="6">

                                                <TextBlock FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="Position: "/>
                                                    <Run Text="{Binding Position}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="Weight: "/>
                                                    <Run Text="{Binding Weight}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="Class Profile: "/>
                                                    <Run Text="{Binding ClassProfileDisplay}"/>
                                                </TextBlock>

                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="Delete"
                                                    Classes="blockBtn"
                                                    VerticalAlignment="Center"
                                                    Click="DeleteScenarioSlot_Click"/>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>

                </ScrollViewer>

                <StackPanel Grid.Row="3"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Center">

                    <Button Content="Close"
                            Classes="closeBtn"
                            Command="{Binding ClearSelectionCommand}"/>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>