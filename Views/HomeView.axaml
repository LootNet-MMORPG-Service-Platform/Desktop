<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:desktop_app.ViewModels"
             xmlns:views="clr-namespace:desktop_app.Views"
             x:Class="desktop_app.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             x:Name="Root">

    <Grid RowDefinitions="72,*" ColumnDefinitions="240,*"
          Background="{DynamicResource AppBackgroundBrush}">

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource TopbarBrush}"
                BorderBrush="{DynamicResource TopbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,0">

            <Grid ColumnDefinitions="*,Auto,Auto"
                  VerticalAlignment="Center">

                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center"
                            Spacing="2">

                    <TextBlock Text="LootNet-MMORPG Admin Panel"
                               Foreground="{DynamicResource WhiteBrush}"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage the world of LootNet from one place"
                               Foreground="{DynamicResource TextOnDarkMutedBrush}"
                               FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0">

                    <TextBlock.Text>
                        <MultiBinding StringFormat="Welcome, {0}! ({1})">
                            <Binding Path="Username"/>
                            <Binding Path="Role"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <Button Grid.Column="2"
                        Classes="logoutBtn"
                        Content="Logout"
                        Command="{Binding LogoutCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,1,1,0"
                Padding="18,22">

            <StackPanel Spacing="10">
                <TextBlock Text="NAVIGATION"
                           Foreground="{DynamicResource TextOnDarkMutedBrush}"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="8,0,0,10"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsDashboardActive}"
                        Content="Dashboard"
                        Command="{Binding ShowDashboardCommand}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsUsersActive}"
                        Content="Users"
                        Command="{Binding ShowUsersCommand}"
                        IsVisible="{Binding CanAccessUsers}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsItemGenerationActive}"
                        Content="Item Generation"
                        Command="{Binding ShowItemGenerationCommand}"
                        IsVisible="{Binding CanAccessItemGeneration}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsEconomyActive}"
                        Content="Economy"
                        Command="{Binding ShowEconomyCommand}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsLogsActive}"
                        Content="Logs"
                        Command="{Binding ShowLogsCommand}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      AllowAutoHide="False"
                      VerticalScrollBarVisibility="Auto">

            <Grid Margin="24"
                  RowDefinitions="Auto,18,Auto">

                <StackPanel Grid.Row="0"
                            Spacing="4">
                    <TextBlock Text="{Binding CurrentSectionTitle}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="{Binding CurrentSectionDescription}"
                               FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <Grid Grid.Row="2"
                      IsVisible="{Binding IsUsersActive}">

                    <views:UsersView DataContext="{Binding UsersVm}" />

                </Grid>
                
                <Grid Grid.Row="2"
                      IsVisible="{Binding IsItemGenerationActive}">

                    <views:ItemGenerationView DataContext="{Binding ItemGenerationVm}" />

                </Grid>

                

            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>