<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:desktop_app.ViewModels"
             xmlns:models="clr-namespace:desktop_app.Models"
             xmlns:conv="clr-namespace:desktop_app.Converters"
             x:Class="desktop_app.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             x:Name="Root">

    <Grid RowDefinitions="72,*" ColumnDefinitions="240,*"
          Background="{DynamicResource AppBackgroundBrush}">

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource TopbarBrush}"
                BorderBrush="{DynamicResource TopbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,0">

            <Grid ColumnDefinitions="*,Auto,Auto"
                  VerticalAlignment="Center">

                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="LootNet-MMORPG Admin Panel"
                               Foreground="{DynamicResource WhiteBrush}"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage the world of LootNet from one place"
                               Foreground="{DynamicResource TextOnDarkMutedBrush}"
                               FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0">

                    <TextBlock.Text>
                        <MultiBinding StringFormat="Welcome, {0}! ({1})">
                            <Binding Path="Username"/>
                            <Binding Path="Role"/>
                        </MultiBinding>
                    </TextBlock.Text>

                </TextBlock>

                <Button Grid.Column="2"
                        Classes="logoutBtn"
                        Content="Logout"
                        Command="{Binding LogoutCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,1,1,0"
                Padding="18,22">

            <StackPanel Spacing="10">

                <TextBlock Text="NAVIGATION"
                           Foreground="{DynamicResource TextOnDarkMutedBrush}"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="8,0,0,10"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsDashboardActive}"
                        Content="Dashboard"
                        Command="{Binding ShowDashboardCommand}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsUsersActive}"
                        Content="Users"
                        Command="{Binding ShowUsersCommand}"
                        IsVisible="{Binding CanAccessUsers}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsItemsActive}"
                        Content="Items"
                        Command="{Binding ShowItemsCommand}"
                        IsVisible="{Binding CanAccessItems}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsEconomyActive}"
                        Content="Economy"
                        Command="{Binding ShowEconomyCommand}"/>

                <Button Classes.navBtn="True"
                        Classes.active="{Binding IsLogsActive}"
                        Content="Logs"
                        Command="{Binding ShowLogsCommand}"/>

            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      AllowAutoHide="False"
                      VerticalScrollBarVisibility="Auto">

            <Grid Margin="24"
                  ColumnDefinitions="*,320"
                  RowDefinitions="Auto,18,Auto,18,Auto">

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Spacing="4">
                    <TextBlock Text="{Binding CurrentSectionTitle}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="{Binding CurrentSectionDescription}"
                               FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <!-- FILTERS -->
                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsUsersActive}">

                    <TextBox Width="280"
                             Height="42"
                             Watermark="Search username..."
                             Text="{Binding UsersVm.SearchText}" />

                    <ComboBox Width="160"
                              Height="42"
                              CornerRadius="10"
                              ItemsSource="{Binding UsersVm.RoleOptions}"
                              SelectedItem="{Binding UsersVm.SelectedRole}" />

                    <ComboBox Width="150"
                              Height="42"
                              CornerRadius="10"
                              ItemsSource="{Binding UsersVm.StatusOptions}"
                              SelectedItem="{Binding UsersVm.SelectedBlockedStatus}" />

                    <Button Content="Clear"
                            Height="42"
                            Classes="unblockBtn"
                            Command="{Binding UsersVm.ClearFiltersCommand}" />

                </StackPanel>

                <Border Grid.Row="4"
                        Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="18"
                        Padding="22"
                        VerticalAlignment="Top"
                        BoxShadow="0 10 30 0 #14000000">

                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding CurrentSectionTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding CurrentSectionMessage}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <StackPanel IsVisible="{Binding IsUsersActive}">

                            <Border Background="{DynamicResource MutedSurfaceBrush}"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,10,0,0">

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="Username"
                                               FontWeight="Bold"
                                               Width="120"/>

                                    <TextBlock Text="Role"
                                               FontWeight="Bold"
                                               Width="120"/>

                                    <TextBlock Text="Currency"
                                               FontWeight="Bold"
                                               Width="100"/>

                                    <TextBlock Text="IsBlocked"
                                               FontWeight="Bold"
                                               Width="80"/>

                                    <TextBlock Text="Actions"
                                               FontWeight="Bold"
                                               Width="230"/>
                                </StackPanel>

                            </Border>

                            <ItemsControl ItemsSource="{Binding UsersVm.Users}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AdminUser">
                                        <Border Background="{DynamicResource CardBrush}"
                                                CornerRadius="10"
                                                Padding="10"
                                                Margin="0,6,0,0">

                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding Username}"
                                                           FontWeight="Bold"
                                                           Width="120"/>

                                                <TextBlock Text="{Binding Role}"
                                                           Width="120"/>

                                                <TextBlock Text="{Binding Currency}"
                                                           Width="100"/>

                                                <TextBlock Width="80">
                                                    <TextBlock.Text>
                                                        <Binding Path="IsBlocked">
                                                            <Binding.Converter>
                                                                <conv:BooleanToStatusConverter/>
                                                            </Binding.Converter>
                                                        </Binding>
                                                    </TextBlock.Text>
                                                </TextBlock>

                                                <StackPanel Orientation="Horizontal" Spacing="10" Width="230">
                                                    <Button Width="100"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            Click="SelectUser_Click"
                                                            Classes="detailsBtn"
                                                            Content="Details"/>

                                                    <Button Width="100"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            Click="ToggleBlockStatus_Click"
                                                            Classes="blockBtn"
                                                            IsVisible="{Binding !IsBlocked}"
                                                            IsEnabled="{Binding CanToggleBlock}"
                                                            Content="Block"/>

                                                    <Button Width="100"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            Click="ToggleBlockStatus_Click"
                                                            Classes="unblockBtn"
                                                            IsVisible="{Binding IsBlocked}"
                                                            IsEnabled="{Binding CanToggleBlock}"
                                                            Content="Unblock"/>
                                                </StackPanel>
                                            </StackPanel>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="10"
                                        Margin="0,20,0,0">

                                <Button Content="Previous"
                                        Classes="detailsBtn"
                                        Command="{Binding UsersVm.PreviousPageCommand}"
                                        IsEnabled="{Binding UsersVm.CanGoPrevious}" />

                                <TextBlock Text="{Binding UsersVm.CurrentPage}" VerticalAlignment="Center" />
                                <TextBlock Text=" / " VerticalAlignment="Center" />
                                <TextBlock Text="{Binding UsersVm.TotalPages}" VerticalAlignment="Center" />

                                <Button Content="Next"
                                        Classes="detailsBtn"
                                        Command="{Binding UsersVm.NextPageCommand}"
                                        IsEnabled="{Binding UsersVm.CanGoNext}" />

                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Grid.Column="1"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="18"
                        Padding="20"
                        Margin="20,0,0,0"
                        Height="555"
                        VerticalAlignment="Top"
                        BoxShadow="0 10 30 0 #14000000"
                        IsVisible="{Binding UsersVm.HasSelectedUser}">

                    <Grid RowDefinitions="Auto,Auto,*,Auto">

                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="User Details"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Spacing="10"
                                    Margin="0,20,0,20"
                                    HorizontalAlignment="Center">

                            <Image Source="avares://desktop-app/Assets/user-icon.png"
                                   Width="90"
                                   Height="90"
                                   HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding UsersVm.SelectedUser.Username}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Spacing="12"
                                    Margin="0,20,0,0">

                            <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Role: "/>
                                <Run Text="{Binding UsersVm.SelectedUser.Role}"/>
                            </TextBlock>

                            <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Currency: "/>
                                <Run Text="{Binding UsersVm.SelectedUser.Currency}"/>
                            </TextBlock>

                            <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Blocked: "/>
                                <Run Text="{Binding UsersVm.SelectedUser.IsBlocked}"/>
                            </TextBlock>

                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Orientation="Vertical"
                                    Spacing="10"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Center">

                            <Button Content="Inventory"
                                    Classes="detailsBtn"
                                    Width="140"
                                    Click="Inventory_Click"/>

                            <Button Content="Equipment"
                                    Classes="detailsBtn"
                                    Width="140"
                                    Click="Equipment_Click"/>

                            <Button Content="Change Role"
                                    Classes="detailsBtn"
                                    Width="140"
                                    Click="ChangeRole_Click"
                                    IsEnabled="{Binding UsersVm.CanChangeSelectedUserRole}"/>

                            <Button Content="Close"
                                    Classes="unblockBtn"
                                    Command="{Binding UsersVm.CloseSelectionCommand}"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>