<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:desktop_app.ViewModels.Generation"
             xmlns:models="clr-namespace:desktop_app.Models.Generation"
             x:Class="desktop_app.Views.ItemGenerationView"
             x:DataType="vm:ItemGenerationViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="*,560"
          ColumnSpacing="20">

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22"
                VerticalAlignment="Top"
                BoxShadow="0 12 40 0 #66000000">

            <StackPanel Spacing="14">

                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Generation Profiles"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Create"
                            Classes="detailsBtn"
                            Width="110"
                            Click="CreateProfile_Click"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:GenerationProfile">
                            <Border Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,6,0,0">

                                <Grid ColumnDefinitions="4,*,Auto"
                                      ColumnSpacing="12">

                                    <Border Grid.Column="0"
                                            Background="{DynamicResource InfoBrush}"
                                            CornerRadius="4"/>

                                    <StackPanel Grid.Column="1"
                                                Spacing="3"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Item generation configuration profile"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Details"
                                            Width="100"
                                            Classes="detailsBtn"
                                            Command="{Binding #Root.((vm:ItemGenerationViewModel)DataContext).SelectProfileCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20"
                Height="560"
                VerticalAlignment="Top"
                BoxShadow="0 12 40 0 #66000000"
                IsVisible="{Binding HasSelectedProfile}">

            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Profile Details"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Text="{Binding SelectedProfile.Name}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#3316A34A"
                            BorderBrush="{DynamicResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            IsVisible="{Binding !IsProfileIncomplete}">
                        <TextBlock Text="COMPLETE"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#BBF7D0"/>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#33DC2626"
                            BorderBrush="{DynamicResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsProfileIncomplete}">
                        <TextBlock Text="INCOMPLETE"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#FECACA"/>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False">

                    <StackPanel Spacing="12">

                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,18,0,10">

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Type Weights"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Defines how often specific item types can be generated."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Add Type Weight"
                                        Classes="detailsBtn"
                                        Click="AddTypeWeight_Click"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="No type weights yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsVisible="{Binding !HasWeights}"/>

                        <ItemsControl ItemsSource="{Binding Weights}"
                                      IsVisible="{Binding HasWeights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TypeWeight">
                                    <Border Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="0,0,0,6">

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">

                                            <StackPanel Grid.Column="0"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">

                                                <TextBlock FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="{Binding Category}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding TypeDisplay}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="Weight: "/>
                                                    <Run Text="{Binding Weight}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">

                                                <Button Content="Edit"
                                                        Classes="detailsBtn"
                                                        Click="EditTypeWeight_Click"/>

                                                <Button Content="Delete"
                                                        Classes="blockBtn"
                                                        Click="DeleteTypeWeight_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Rules"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Rules describe what can be generated and how fallback generation behaves."
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Add Rule"
                                        Classes="detailsBtn"
                                        Width="120"
                                        Click="AddRule_Click"/>
                            </Grid>
                        </Border>
                        
                                                <ItemsControl ItemsSource="{Binding Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:GenerationRule">

                                    <Border Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10">

                                        <StackPanel Spacing="12">

                                            <Grid ColumnDefinitions="*,Auto">

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">

                                                    <Border Background="#1E3A8A"
                                                            CornerRadius="10"
                                                            Padding="10,4">
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White">
                                                            <Run Text="{Binding TypeLabel}"/>
                                                            <Run Text="{Binding TypeValue}"/>
                                                        </TextBlock>
                                                    </Border>

                                                    <Border Background="#7F1D1D"
                                                            CornerRadius="10"
                                                            Padding="10,4"
                                                            IsVisible="{Binding IsFallback}">
                                                        <TextBlock Text="Fallback"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FECACA"/>
                                                    </Border>

                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8">

                                                    <Button Content="Edit"
                                                            Classes="detailsBtn"
                                                            Click="EditRule_Click"/>

                                                    <Button Content="Delete"
                                                            Classes="blockBtn"
                                                            Click="DeleteRule_Click"/>

                                                </StackPanel>
                                            </Grid>

                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">

                                                <StackPanel Spacing="10">

                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="Parameters"
                                                                   FontWeight="Bold"
                                                                   FontSize="14"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                                        <Button Grid.Column="1"
                                                                Content="Add Parameter"
                                                                Classes="detailsBtn"
                                                                Width="130"
                                                                Click="AddParameter_Click"
                                                                DataContext="{Binding}"/>
                                                    </Grid>

                                                    <TextBlock Text="No parameters assigned"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               IsVisible="{Binding !HasParameters}"/>

                                                    <ItemsControl ItemsSource="{Binding Parameters}"
                                                                  IsVisible="{Binding HasParameters}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:GenerationParameter">

                                                                <Border Background="{DynamicResource CardBrush}"
                                                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="0,0,0,8">

                                                                    <Grid ColumnDefinitions="*,Auto">

                                                                        <StackPanel Spacing="2">

                                                                            <TextBlock Text="{Binding Parameter}"
                                                                                    FontWeight="SemiBold"
                                                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>

                                                                            <TextBlock Text="No segments yet"
                                                                                    FontSize="12"
                                                                                    Margin="14,0,0,0"
                                                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                                                    IsVisible="{Binding !HasSegments}"/>

                                                                            <ItemsControl ItemsSource="{Binding Segments}"
                                                                                    IsVisible="{Binding HasSegments}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="models:Segment">

                                                                                        <TextBlock FontSize="12"
                                                                                            Margin="14,0,0,0"
                                                                                            Foreground="{DynamicResource TextMutedBrush}">

                                                                                            <Run Text="Min: "/>
                                                                                            <Run Text="{Binding Min}"/>

                                                                                            <Run Text=", Max: "/>
                                                                                            <Run Text="{Binding Max}"/>

                                                                                            <Run Text=", Weight: "/>
                                                                                            <Run Text="{Binding Weight}"/>

                                                                                        </TextBlock>

                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>

                                                                        </StackPanel>

                                                                        <Button Grid.Column="1"
                                                                                Content="Delete"
                                                                                Classes="blockBtn"
                                                                                Click="DeleteParameter_Click"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                </StackPanel>
                                            </Border>

                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">

                                                <StackPanel Spacing="10">

                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="Elements"
                                                                   FontWeight="Bold"
                                                                   FontSize="14"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                                        <Button Grid.Column="1"
                                                                Content="Add Element"
                                                                Classes="detailsBtn"
                                                                Width="120"
                                                                Click="AddElement_Click"
                                                                DataContext="{Binding}"/>
                                                    </Grid>

                                                    <TextBlock Text="No elements assigned"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               IsVisible="{Binding !HasElements}"/>

                                                    <ItemsControl ItemsSource="{Binding Elements}"
                                                                  IsVisible="{Binding HasElements}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:GenerationElement">

                                                                <Border Background="{DynamicResource CardBrush}"
                                                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="0,0,0,8">

                                                                    <Grid ColumnDefinitions="*,Auto">

                                                                        <StackPanel Spacing="2">

                                                                            <TextBlock Text="{Binding ElementType}"
                                                                                    FontWeight="SemiBold"
                                                                                    Foreground="{DynamicResource TextPrimaryBrush}"/>

                                                                            <TextBlock Text="No segments yet"
                                                                                    FontSize="12"
                                                                                    Margin="14,0,0,0"
                                                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                                                    IsVisible="{Binding !HasSegments}"/>

                                                                            <ItemsControl ItemsSource="{Binding Segments}"
                                                                                    IsVisible="{Binding HasSegments}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="models:Segment">

                                                                                        <TextBlock FontSize="12"
                                                                                            Margin="14,0,0,0"
                                                                                            Foreground="{DynamicResource TextMutedBrush}">

                                                                                            <Run Text="Min: "/>
                                                                                            <Run Text="{Binding Min}"/>

                                                                                            <Run Text=", Max: "/>
                                                                                            <Run Text="{Binding Max}"/>

                                                                                            <Run Text=", Weight: "/>
                                                                                            <Run Text="{Binding Weight}"/>

                                                                                        </TextBlock>

                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>

                                                                        </StackPanel>

                                                                        <Button Grid.Column="1"
                                                                                Content="Delete"
                                                                                Classes="blockBtn"
                                                                                Click="DeleteElement_Click"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                </StackPanel>
                                            </Border>

                                        </StackPanel>

                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                </ScrollViewer>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">

                    <Button Content="Delete Profile"
                            Classes="blockBtn"
                            Width="140"
                            Click="DeleteProfile_Click"/>

                    <Button Content="Close"
                            Classes="closeBtn"
                            Width="120"
                            Margin="10,0,0,0"
                            Command="{Binding CloseSelectionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
