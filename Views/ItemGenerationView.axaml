<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:desktop_app.ViewModels.Generation"
             xmlns:models="clr-namespace:desktop_app.Models.Generation"
             x:Class="desktop_app.Views.ItemGenerationView"
             x:DataType="vm:ItemGenerationViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="*,320">

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="18"
                Padding="22"
                VerticalAlignment="Top"
                BoxShadow="0 10 30 0 #14000000">

            <StackPanel Spacing="8">

                <TextBlock Text="Generation Profiles"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <Button Content="Create Profile"
                        Classes="detailsBtn"
                        Width="140"
                        HorizontalAlignment="Left"
                        Click="CreateProfile_Click"/>

                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:GenerationProfile">
                            <Border Background="{DynamicResource CardBrush}"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,6,0,0">

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Column="1"
                                            Content="Details"
                                            Width="100"
                                            Classes="detailsBtn"
                                            Command="{Binding #Root.((vm:ItemGenerationViewModel)DataContext).SelectProfileCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="18"
                Padding="20"
                Margin="20,0,0,0"
                Height="530"
                VerticalAlignment="Top"
                BoxShadow="0 10 30 0 #14000000"
                IsVisible="{Binding HasSelectedProfile}">

            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <TextBlock Grid.Row="0"
                           Text="Profile Details"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel Grid.Row="1"
                            Spacing="6"
                            Margin="0,20,0,10"
                            HorizontalAlignment="Center">

                    <TextBlock Text="{Binding SelectedProfile.Name}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False"
                              Margin="0,10,0,0">

                    <StackPanel Spacing="10">

                        <TextBlock Text="Type Weights"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,6,0,0"/>

                        <TextBlock Text="No type weights yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   IsVisible="{Binding !HasWeights}"/>

                        <ItemsControl ItemsSource="{Binding Weights}"
                                      IsVisible="{Binding HasWeights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TypeWeight">
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="- "/>
                                        <Run Text="{Binding Category}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding WeaponType}"/>
                                        <Run Text="{Binding ArmorType}"/>
                                        <Run Text=", weight: "/>
                                        <Run Text="{Binding Weight}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Rules"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,12,0,0"/>
                        
                        <Button Content="Add Rule"
                                Classes="detailsBtn"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,6"
                                Click="AddRule_Click"/>

                        <TextBlock Text="No rules yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   IsVisible="{Binding !HasRules}"/>

                        <ItemsControl ItemsSource="{Binding Rules}"
                                      IsVisible="{Binding HasRules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:GenerationRule">
                                    <Border Background="{DynamicResource CardBrush}"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,4,0,0">

                                        <StackPanel Spacing="8">

                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                                <Run Text="Category: "/>
                                                <Run Text="{Binding Category}"/>
                                            </TextBlock>

                                            <TextBlock FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="Weapon: "/>
                                                <Run Text="{Binding WeaponType}"/>
                                            </TextBlock>

                                            <TextBlock Text="Parameters"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Margin="0,6,0,0"/>
                                            
                                            <Button Content="Add Parameter"
                                                    Classes="detailsBtn"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,4,0,6"
                                                    Click="AddParameter_Click"/>

                                            <TextBlock Text="No parameters"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       IsVisible="{Binding !HasParameters}"/>

                                            <ItemsControl ItemsSource="{Binding Parameters}"
                                                          IsVisible="{Binding HasParameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:GenerationParameter">
                                                        <StackPanel Spacing="3"
                                                                    Margin="0,2,0,6">

                                                            <TextBlock FontSize="13"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                                <Run Text="- "/>
                                                                <Run Text="{Binding Parameter}"/>
                                                            </TextBlock>

                                                            <ItemsControl ItemsSource="{Binding Segments}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="models:Segment">
                                                                        <TextBlock FontSize="12"
                                                                                   Margin="14,0,0,0"
                                                                                   Foreground="{DynamicResource TextMutedBrush}">
                                                                            <Run Text="range: "/>
                                                                            <Run Text="{Binding Min}"/>
                                                                            <Run Text=" - "/>
                                                                            <Run Text="{Binding Max}"/>
                                                                            <Run Text=", weight: "/>
                                                                            <Run Text="{Binding Weight}"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Elements"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Margin="0,6,0,0"/>
                                            
                                            <Button Content="Add Element"
                                                    Classes="detailsBtn"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,4,0,6"
                                                    Click="AddElement_Click"/>

                                            <TextBlock Text="No elements"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       IsVisible="{Binding !HasElements}"/>

                                            <ItemsControl ItemsSource="{Binding Elements}"
                                                          IsVisible="{Binding HasElements}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:GenerationElement">
                                                        <StackPanel Spacing="3"
                                                                    Margin="0,2,0,6">

                                                            <TextBlock FontSize="13"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                                <Run Text="- "/>
                                                                <Run Text="{Binding ElementType}"/>
                                                            </TextBlock>

                                                            <ItemsControl ItemsSource="{Binding Segments}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="models:Segment">
                                                                        <TextBlock FontSize="12"
                                                                                   Margin="14,0,0,0"
                                                                                   Foreground="{DynamicResource TextMutedBrush}">
                                                                            <Run Text="range: "/>
                                                                            <Run Text="{Binding Min}"/>
                                                                            <Run Text=" - "/>
                                                                            <Run Text="{Binding Max}"/>
                                                                            <Run Text=", weight: "/>
                                                                            <Run Text="{Binding Weight}"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="Delete Rule"
                                                    Classes="blockBtn"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,8,0,0"
                                                    Click="DeleteRule_Click"/>
                                            
                                        </StackPanel>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                </ScrollViewer>

                <StackPanel Grid.Row="3"
                            Orientation="Vertical"
                            Spacing="10"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center">

                    <Button Content="Delete"
                            Classes="blockBtn"
                            Width="140"
                            Click="DeleteProfile_Click"/>

                    <Button Content="Close"
                            Classes="unblockBtn"
                            Width="140"
                            Command="{Binding CloseSelectionCommand}"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>