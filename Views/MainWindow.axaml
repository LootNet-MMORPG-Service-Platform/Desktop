<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:desktop_app.Models"
        xmlns:vm="using:desktop_app.ViewModels"
        xmlns:views="using:desktop_app.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="desktop_app.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LootNet-MMORPG"
        Width="1240"
        Height="820"
        MinWidth="1075"
        MinHeight="720"
        Background="{DynamicResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:AuthShellViewModel">
                    <views:AuthShellView/>
                </DataTemplate>

                <DataTemplate DataType="vm:HomeViewModel">
                    <views:HomeView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

        <ItemsControl ItemsSource="{Binding Notifications.Notifications}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="24"
                      IsHitTestVisible="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:NotificationMessage">
                    <Border Width="340"
                            Margin="0,0,0,10"
                            Background="{DynamicResource TopbarBrush}"
                            CornerRadius="10"
                            Padding="14"
                            BoxShadow="0 10 30 0 #33000000">
                        <Grid ColumnDefinitions="4,*">
                            <Border Grid.Column="0"
                                    Background="{DynamicResource {Binding AccentBrushKey}}"
                                    CornerRadius="3"/>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Spacing="4">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextOnDarkBrush}"/>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextOnDarkMutedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
