<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:desktop_app.ViewModels"
        xmlns:views="using:desktop_app.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="desktop_app.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LootNet-MMORPG"
        Width="1240"
        Height="820"
        MinWidth="1075"
        MinHeight="720"
        Background="White"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ContentControl Content="{Binding CurrentViewModel}">
        <ContentControl.DataTemplates>
            <DataTemplate DataType="vm:AuthShellViewModel">
                <views:AuthShellView/>
            </DataTemplate>

            <DataTemplate DataType="vm:HomeViewModel">
                <views:HomeView/>
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</Window>