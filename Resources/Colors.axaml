<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#09090B"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#18181B"/>
    <SolidColorBrush x:Key="CardBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="MutedSurfaceBrush" Color="#18181B"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#66000000"/>

    <!-- Topbar / Sidebar -->
    <SolidColorBrush x:Key="TopbarBrush" Color="#18181B"/>
    <SolidColorBrush x:Key="TopbarBorderBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="#18181B"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="SidebarButtonBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="SidebarButtonHoverBrush" Color="#3F3F46"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D4D4D8"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="TextOnDarkMutedBrush" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="TextStrongNeutralBrush" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#71717A"/>

    <!-- Input / borders -->
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="InputTextBrush" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="InputWatermarkHoverBrush" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="NeutralLightBrush" Color="#27272A"/>
    <SolidColorBrush x:Key="NeutralLightHoverBrush" Color="#3F3F46"/>

    <!-- Primary green like web -->
    <SolidColorBrush x:Key="PrColor" Color="#16A34A"/>
    <SolidColorBrush x:Key="PrColorHover" Color="#22C55E"/>

    <!-- Info blue like web -->
    <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#1D4ED8"/>

    <!-- Scroll -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#52525B"/>
    
    <!-- Core -->
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="#00FFFFFF"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#991B1B"/>

    <!-- Success -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#166534"/>

</ResourceDictionary>
