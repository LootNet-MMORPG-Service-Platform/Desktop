<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.PreviewWith>
        <Border Padding="20" Width="400">
            <StackPanel Orientation="Vertical" Spacing="10">
                <TextBox Watermark="Email"/>
                <Button Classes="submitBtn" Content="Login" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="TextBox">
        <Setter Property="CaretBrush" Value="White"/>
        <Style Selector="^ /template/ TextPresenter#PART_TextPresenter">
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.5" Easing="QuarticEaseOut"/>
            </Transitions>
        </Setter>

        <Style Selector="^ /template/ TextBlock#PART_Watermark">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.5" Easing="QuarticEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^ /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.5" Easing="QuarticEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ Border#PART_BorderElement">
                <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrColor}"/>
            </Style>
            <Style Selector="^ /template/ TextBlock#PART_Watermark">
                <Setter Property="Foreground" Value="{DynamicResource InputWatermarkHoverBrush}"/>
            </Style>
        </Style>

        <Style Selector="^:focus">
            <Setter Property="Foreground" Value="{DynamicResource PrColor}"/>
            <Style Selector="^ /template/ Border#PART_BorderElement">
                <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrColor}"/>
            </Style>
        </Style>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="Foreground" Value="#09090B"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="Foreground" Value="#09090B"/>
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="#E5E7EB"/>
        <Setter Property="Foreground" Value="#09090B"/>
    </Style>

    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Background" Value="#DBEAFE"/>
        <Setter Property="Foreground" Value="#09090B"/>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="CheckBox /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="CheckBox:pointerover /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InfoHoverBrush}"/>
    </Style>

    <Style Selector="CheckBox.fallbackCheckBox">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Background="{DynamicResource TransparentBrush}">
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Background="{DynamicResource TransparentBrush}"
                                BorderBrush="{DynamicResource WhiteBrush}"
                                BorderThickness="2"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                            <Path x:Name="CheckMark"
                                  Data="M2,5 L5,8 L11,2"
                                  Stroke="{DynamicResource WhiteBrush}"
                                  StrokeThickness="2"
                                  Width="13"
                                  Height="10"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="False"/>
                        </Border>

                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="CheckBox.fallbackCheckBox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
    </Style>

    <Style Selector="CheckBox.fallbackCheckBox:checked /template/ Border#Box">
        <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="CheckBox.fallbackCheckBox:checked /template/ Path#CheckMark">
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="ToggleSwitch:disabled">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="ToggleSwitch:disabled /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="ToggleSwitch:disabled /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="#55FFFFFF"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="ToggleSwitch:disabled /template/ Border#PART_SwitchKnob">
        <Setter Property="Background" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="ToggleSwitch:disabled /template/ Ellipse#PART_SwitchKnob">
        <Setter Property="Fill" Value="{DynamicResource WhiteBrush}"/>
    </Style>

    <Style Selector="Button.submitBtn">
        <Setter Property="Height" Value="50"/>
        <Setter Property="Background" Value="{DynamicResource PrColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="25">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource PrColorHover}"/>
        </Style>
    </Style>

    <Style Selector="Button.navBtn">
        <Setter Property="Height" Value="52"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{DynamicResource SidebarButtonBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnDarkBrush}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            HorizontalAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="16,0">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource SidebarButtonHoverBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.navBtn.active">
        <Setter Property="Background" Value="{DynamicResource PrColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource PrColorHover}"/>
        </Style>
    </Style>

    <Style Selector="Button.logoutBtn">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="18,10"
                            MinWidth="110">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkMutedBrush}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource TextDisabledBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.closeBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="12,8"
                            MinWidth="100">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkMutedBrush}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource TextDisabledBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.actionBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="12,8"
                            MinWidth="100">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.blockBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="12,8"
                            MinWidth="100">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkMutedBrush}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource TextDisabledBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.unblockBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="12,8"
                            MinWidth="100">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource SuccessPressedBrush}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkMutedBrush}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource TextDisabledBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.dialogConfirmBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="12,8"
                            MinWidth="90">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource InfoHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource InfoPressedBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.dialogCancelBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="12,8"
                            MinWidth="90">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        </Style>
    </Style>

    <Style Selector="Button.detailsBtn">
        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="12,8"
                            MinWidth="100">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource InfoHoverBrush}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource InfoPressedBrush}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkMutedBrush}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource TextDisabledBrush}"/>
        </Style>
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="10"/>
    </Style>

    <Style Selector="ScrollBar:vertical /template/ RepeatButton#PART_LineUpButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="ScrollBar:vertical /template/ RepeatButton#PART_LineDownButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="ScrollBar:vertical /template/ Thumb">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}"/>
    </Style>

    <Style Selector="ScrollBar:vertical:pointerover /template/ Thumb">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}"/>
    </Style>

    <Style Selector="ScrollBar:vertical:pressed /template/ Thumb">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}"/>
    </Style>

    <Style Selector="Button.backBtn">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,6"/>

        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Background="Transparent"
                        Padding="{TemplateBinding Padding}">
                    <TextBlock Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               FontWeight="{TemplateBinding FontWeight}"
                               FontSize="{TemplateBinding FontSize}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="#F4F4F5"/>
        </Style>
    </Style>
</Styles>
